# Copy this file to ".env" (same folder) and fill in the values from your Xero app:
#   Xero Developer portal -> My Apps -> your app -> Configuration
#
# IMPORTANT: .env is git-ignored. Never commit real credentials.

# ---- Required ----
XERO_CLIENT_ID=your-client-id-here
XERO_CLIENT_SECRET=your-client-secret-here

# Must EXACTLY match a Redirect URI registered on the Xero app.
XERO_REDIRECT_URI=http://localhost:3000/callback

# ---- Optional ----
PORT=3000

# Space-separated OAuth scopes. The defaults below cover report downloading.
# XERO_SCOPES=openid profile email offline_access accounting.reports.read accounting.settings.read accounting.transactions.read accounting.contacts.read

# When you later host the frontend separately (e.g. GitHub Pages), set this to
# that exact origin to stop other sites using your proxy. "*" is fine locally.
# ALLOWED_ORIGIN=https://your-name.github.io
